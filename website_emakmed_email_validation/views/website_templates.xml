<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="auth_signup_fields_extended" inherit_id="auth_signup.fields" name="Extended Signup Fields">
        <xpath expr="//div[hasclass('field-name')]" position="after">
            <div class="mb-3 field-phone">
                <label for="phone">Numéro de téléphone</label>
                <input type="text" name="phone" t-att-value="phone" id="phone" class="form-control form-control-sm" placeholder="Votre numéro de téléphone" required="required" t-att-readonly="'readonly' if only_passwords else None" />
            </div>
            <div class="mb-3 field-street">
                <label for="street">Adresse de facturation et livraison</label>
                <input type="text" name="street" t-att-value="street" id="street" class="form-control form-control-sm" placeholder="Ex: Lot II A 3 K Amboditsiry..." required="required" t-att-readonly="'readonly' if only_passwords else None" />
            </div>
        </xpath>
    </template>

    <template id="email_verification_required_template" name="Email Verification Required">
        <t t-call="website.layout">
            <div id="wrap">
                <div class="container mt-5 mb-5">
                    <div class="row justify-content-center">
                        <div class="col-md-8 text-center">
                            <div class="alert alert-warning" role="alert">
                                <h4 class="alert-heading">Vérification de l'email requise !</h4>
                                <p>Pour des raisons de sécurité et pour valider votre commande, vous devez d'abord vérifier votre adresse email.</p>
                                <hr/>
                                <p class="mb-0">Veuillez vérifier votre boîte de réception (et vos spams) pour trouver l'email de validation.</p>
                            </div>
                            
                            <div class="mt-4">
                                <p>Vous n'avez pas reçu l'email ?</p>
                                <a href="/my/resend_verification_email" class="btn btn-primary">
                                    Renvoyer l'email de vérification
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <template id="email_verification_success_template" name="Email Verification Success">
        <t t-call="website.layout">
            <div id="wrap">
                <div class="container mt-5 mb-5">
                    <div class="row justify-content-center">
                        <div class="col-md-8 text-center">
                            <div class="alert alert-success" role="alert">
                                <h4 class="alert-heading">Félicitations !</h4>
                                <p>Votre adresse email a bien été vérifiée.</p>
                                <hr/>
                                <p class="mb-0">Vous pouvez maintenant reprendre votre navigation et finaliser votre commande.</p>
                            </div>
                            
                            <div class="mt-4">
                                <a href="/shop/cart" class="btn btn-primary">
                                    Retourner au panier
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <template id="email_verification_failed_template" name="Email Verification Failed">
        <t t-call="website.layout">
            <div id="wrap">
                <div class="container mt-5 mb-5">
                    <div class="row justify-content-center">
                        <div class="col-md-8 text-center">
                            <div class="alert alert-danger" role="alert">
                                <h4 class="alert-heading">Erreur de vérification</h4>
                                <p>Le lien de vérification est invalide ou a expiré.</p>
                                <hr/>
                                <p class="mb-0">Veuillez demander un nouveau lien de vérification.</p>
                            </div>
                            
                            <div class="mt-4">
                                <a href="/email_verification_required" class="btn btn-primary">
                                    Demander un nouveau lien
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>
