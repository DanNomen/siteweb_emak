<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Ajout des champs Promotion dans la fiche produit, onglet Ventes -->
    <record id="product_template_form_view_promo" model="ir.ui.view">
        <field name="name">product.template.form.promo.emakhealthcare</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="sale.product_template_form_view"/>
        <field name="arch" type="xml">
            <!-- Insérer après le champ "Étiquettes" dans l'onglet Ventes -->
            <xpath expr="//field[@name='product_tag_ids']" position="after">
                <field name="promo_type" string="Type de promotion" widget="selection"/>
                <field name="promo_description"
                       string="Description de la promotion"
                       invisible="promo_type == False"
                       placeholder="Ex : 1 acheté = 1 offert, -20% jusqu'au 31/07..."/>
            </xpath>
        </field>
    </record>
</odoo>
