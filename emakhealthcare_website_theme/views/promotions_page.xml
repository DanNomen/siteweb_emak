<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ===================================================================
         Page Promotions Emakhealthcare
         Route : /promotions
         Affiche tous les produits ayant une étiquette "Promotion" OU
         un type de promotion défini (promo_type).
         =================================================================== -->
    <template id="promotions_page" name="Emakhealthcare - Page Promotions">
        <t t-call="website.layout">
            <link rel="preconnect" href="https://fonts.googleapis.com"/>
            <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@600;700;800&amp;family=Inter:wght@400;500;600&amp;display=swap" rel="stylesheet"/>
            <div id="wrap" style="background-color: #F8F9FA; font-family: 'Inter', sans-serif; min-height: 80vh;">

                <style>
                    /* ── Bannière Hero ── */
                    .emakhc-promo-hero {
                        background: linear-gradient(135deg, #1B5E20 0%, #2E7D32 40%, #43A047 100%);
                        padding: 3rem 1.5rem;
                        border-radius: 20px;
                        margin-bottom: 2rem;
                        position: relative;
                        overflow: hidden;
                    }
                    .emakhc-promo-hero::before {
                        content: '';
                        position: absolute;
                        top: -30px; right: -30px;
                        width: 200px; height: 200px;
                        background: rgba(255,255,255,0.05);
                        border-radius: 50%;
                    }
                    .emakhc-promo-hero::after {
                        content: '';
                        position: absolute;
                        bottom: -50px; left: -50px;
                        width: 300px; height: 300px;
                        background: rgba(255,255,255,0.04);
                        border-radius: 50%;
                    }
                    /* ── Carte produit ── */
                    .emakhc-promo-card {
                        background: #fff;
                        border-radius: 16px;
                        border: 1px solid #E5E7EB;
                        overflow: hidden;
                        transition: box-shadow 0.2s ease, transform 0.2s ease;
                        position: relative;
                        height: 100%;
                        display: flex;
                        flex-direction: column;
                    }
                    .emakhc-promo-card:hover {
                        box-shadow: 0 8px 28px rgba(0,0,0,0.12);
                        transform: translateY(-4px);
                    }
                    .emakhc-promo-card .product-img {
                        height: 170px;
                        object-fit: contain;
                        padding: 14px;
                        width: 100%;
                    }
                    /* ── Badge type promo ── */
                    .badge-promo-type {
                        display: inline-flex;
                        align-items: center;
                        gap: 4px;
                        background: linear-gradient(135deg, #d32f2f, #ef5350);
                        color: white;
                        font-size: 0.72rem;
                        font-weight: 700;
                        padding: 4px 10px;
                        border-radius: 20px;
                        letter-spacing: 0.3px;
                    }
                    .badge-promo-pct   { background: linear-gradient(135deg, #c62828, #e53935); }
                    .badge-promo-bogo  { background: linear-gradient(135deg, #0277bd, #039be5); }
                    .badge-promo-bundle{ background: linear-gradient(135deg, #6a1b9a, #ab47bc); }
                    .badge-promo-qty   { background: linear-gradient(135deg, #e65100, #fb8c00); }
                    .badge-promo-free_ship { background: linear-gradient(135deg, #2e7d32, #66bb6a); }
                    .badge-promo-other { background: linear-gradient(135deg, #37474f, #78909c); }
                    /* ── Badge rouge absolu ── */
                    .badge-abs {
                        position: absolute;
                        top: 10px; left: 10px;
                        z-index: 2;
                    }
                    /* ── Ruban décoratif ── */
                    .promo-ribbon {
                        background: linear-gradient(135deg, #FFEB3B, #FFC107);
                        color: #212121;
                        font-size: 0.68rem;
                        font-weight: 800;
                        padding: 3px 8px;
                        border-radius: 0 0 8px 8px;
                        letter-spacing: 0.5px;
                        text-transform: uppercase;
                    }
                    /* ── Filtres ── */
                    .promo-filter-btn {
                        border: 2px solid #E5E7EB;
                        border-radius: 30px;
                        padding: 6px 18px;
                        font-size: 0.82rem;
                        font-weight: 600;
                        cursor: pointer;
                        transition: all 0.15s;
                        background: white;
                        color: #374151;
                    }
                    .promo-filter-btn:hover,
                    .promo-filter-btn.active {
                        border-color: #2E7D32;
                        background: #2E7D32;
                        color: white;
                    }
                    /* ── Bouton Ajouter ── */
                    .btn-add-promo {
                        background-color: #2E7D32;
                        color: #fff;
                        border: none;
                        border-radius: 8px;
                        padding: 8px 14px;
                        font-size: 0.85rem;
                        font-weight: 600;
                        width: 100%;
                        cursor: pointer;
                        display: flex;
                        align-items: center;
                        justify-content: center;
                        gap: 6px;
                        transition: background-color 0.2s;
                    }
                    .btn-add-promo:hover { background-color: #1B5E20; }
                    /* ── Sélecteur quantité ── */
                    .qty-selector-promo {
                        display: none;
                        align-items: center;
                        border: 2px solid #2E7D32;
                        border-radius: 8px;
                        overflow: hidden;
                        width: 100%;
                        height: 38px;
                    }
                    .qty-selector-promo.active { display: flex; }
                    .qty-btn-promo {
                        background: #2E7D32; color: white;
                        border: none; width: 40px; height: 100%;
                        font-size: 1.1rem; font-weight: bold;
                        cursor: pointer; flex-shrink: 0;
                    }
                    .qty-btn-promo:hover { background-color: #1B5E20; }
                    .qty-display-promo {
                        flex: 1; text-align: center;
                        font-weight: 700; font-size: 0.95rem; color: #111827;
                    }
                </style>

                <!-- Script panier -->
                <script type="text/javascript">
                    document.addEventListener('DOMContentLoaded', function() {
                        function updateCart(productId, addQty, setQty, onSuccess, onError) {
                            var params = { product_id: parseInt(productId), display: false };
                            if (addQty !== undefined) params.add_qty = addQty;
                            if (setQty !== undefined) params.set_qty = setQty;
                            fetch('/shop/cart/update_json', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
                                credentials: 'same-origin',
                                body: JSON.stringify({ jsonrpc: '2.0', method: 'call', params: params })
                            })
                            .then(res => res.json())
                            .then(data => {
                                if (data &amp;&amp; data.error) { if (onError) onError(data.error); return; }
                                if (data &amp;&amp; data.result &amp;&amp; data.result.warning) { if (onError) onError(data.result.warning); return; }
                                if (data &amp;&amp; data.result &amp;&amp; typeof data.result.cart_quantity !== 'undefined') {
                                    document.querySelectorAll('.my_cart_quantity').forEach(el => el.textContent = data.result.cart_quantity);
                                    if (typeof data.result.amount !== 'undefined') {
                                        var fmt = new Intl.NumberFormat('fr-FR').format(data.result.amount).replace(',', ' ') + ' CFA';
                                        document.querySelectorAll('.my_cart_amount').forEach(el => el.textContent = fmt);
                                    }
                                    if (onSuccess) onSuccess(data.result);
                                } else { if (onError) onError(data); }
                            })
                            .catch(function(err) { if (onError) onError(err); });
                        }

                        document.querySelectorAll('.btn-add-promo').forEach(function(btn) {
                            btn.addEventListener('click', function() {
                                var card = btn.closest('.promo-cart-wrap');
                                var productId = btn.dataset.productId;
                                var qtySelector = card.querySelector('.qty-selector-promo');
                                var qtyDisplay = card.querySelector('.qty-display-promo');
                                btn.disabled = true;
                                updateCart(productId, 1, undefined, function() {
                                    btn.style.display = 'none';
                                    btn.disabled = false;
                                    qtySelector.classList.add('active');
                                    qtySelector.style.display = 'flex';
                                    qtyDisplay.textContent = '1';
                                    qtySelector.dataset.qty = '1';
                                    qtySelector.dataset.productId = productId;
                                }, function() { btn.disabled = false; });
                            });
                        });

                        document.querySelectorAll('.qty-btn-promo.qty-plus-promo').forEach(function(plusBtn) {
                            plusBtn.addEventListener('click', function() {
                                var selector = plusBtn.closest('.qty-selector-promo');
                                var currentQty = parseInt(selector.dataset.qty);
                                var productId = selector.dataset.productId;
                                plusBtn.disabled = true;
                                updateCart(productId, 1, undefined, function() {
                                    var newQty = currentQty + 1;
                                    selector.dataset.qty = newQty;
                                    selector.querySelector('.qty-display-promo').textContent = newQty;
                                    plusBtn.disabled = false;
                                }, function() { plusBtn.disabled = false; });
                            });
                        });

                        document.querySelectorAll('.qty-btn-promo.qty-minus-promo').forEach(function(minusBtn) {
                            minusBtn.addEventListener('click', function() {
                                var selector = minusBtn.closest('.qty-selector-promo');
                                var currentQty = parseInt(selector.dataset.qty);
                                var productId = selector.dataset.productId;
                                var card = minusBtn.closest('.promo-cart-wrap');
                                var addBtn = card.querySelector('.btn-add-promo');
                                minusBtn.disabled = true;
                                if (currentQty &lt;= 1) {
                                    updateCart(productId, undefined, 0, function() {
                                        selector.classList.remove('active');
                                        selector.style.display = 'none';
                                        addBtn.style.display = 'flex';
                                        selector.dataset.qty = '0';
                                        minusBtn.disabled = false;
                                    }, function() { minusBtn.disabled = false; });
                                } else {
                                    updateCart(productId, -1, undefined, function() {
                                        var newQty = currentQty - 1;
                                        selector.dataset.qty = newQty;
                                        selector.querySelector('.qty-display-promo').textContent = newQty;
                                        minusBtn.disabled = false;
                                    }, function() { minusBtn.disabled = false; });
                                }
                            });
                        });

                        /* Filtres par type */
                        document.querySelectorAll('.promo-filter-btn').forEach(function(btn) {
                            btn.addEventListener('click', function() {
                                document.querySelectorAll('.promo-filter-btn').forEach(b => b.classList.remove('active'));
                                btn.classList.add('active');
                                var filter = btn.dataset.filter;
                                document.querySelectorAll('.promo-product-col').forEach(function(col) {
                                    if (filter === 'all') {
                                        col.style.display = '';
                                    } else {
                                        col.style.display = col.dataset.promoType === filter ? '' : 'none';
                                    }
                                });
                            });
                        });
                    });
                </script>

                <div class="container py-4">

                    <!-- Hero Bannière -->
                    <div class="emakhc-promo-hero mb-4 z-1 position-relative">
                        <div class="row align-items-center">
                            <div class="col-lg-8">
                                <div class="text-warning fw-bold mb-2" style="font-size: 0.85rem; letter-spacing: 2px; text-transform: uppercase;">
                                    <i class="fa fa-tag me-2"/>Offres spéciales
                                </div>
                                <h1 class="text-white fw-bold mb-2" style="font-family: 'Poppins', sans-serif; font-size: 2rem;">
                                    Nos Promotions du moment
                                </h1>
                                <p class="text-white mb-0" style="opacity: 0.85; font-size: 0.95rem;">
                                    Profitez de nos offres exclusives sur une large sélection de produits médicaux et pharmaceutiques.
                                </p>
                            </div>
                            <div class="col-lg-4 text-center mt-3 mt-lg-0">
                                <div class="text-white fw-bold" style="font-size: 2.5rem; font-family: 'Poppins', sans-serif;">
                                    <t t-esc="product_count"/>
                                </div>
                                <div class="text-white" style="opacity: 0.8; font-size: 0.9rem;">produit(s) en promotion</div>
                            </div>
                        </div>
                    </div>

                    <!-- Filtres par type de promotion -->
                    <div class="d-flex flex-wrap gap-2 mb-4">
                        <button class="promo-filter-btn active" data-filter="all">
                            <i class="fa fa-th me-1"/>Toutes les promos
                        </button>
                        <button class="promo-filter-btn" data-filter="pct">
                            <i class="fa fa-percent me-1"/>Remise %
                        </button>
                        <button class="promo-filter-btn" data-filter="bogo">
                            <i class="fa fa-gift me-1"/>1 acheté = 1 offert
                        </button>
                        <button class="promo-filter-btn" data-filter="bundle">
                            <i class="fa fa-archive me-1"/>Pack / Bundle
                        </button>
                        <button class="promo-filter-btn" data-filter="qty">
                            <i class="fa fa-cubes me-1"/>Remise quantité
                        </button>
                        <button class="promo-filter-btn" data-filter="free_ship">
                            <i class="fa fa-truck me-1"/>Livraison gratuite
                        </button>
                    </div>

                    <!-- Grille produits en promo -->
                    <t t-if="products">
                        <div class="row g-3">
                            <t t-foreach="products" t-as="product">
                                <t t-set="has_price_promo" t-value="product.compare_list_price and product.compare_list_price > product.list_price"/>
                                <t t-set="discount" t-value="round(100 - (product.list_price * 100 / product.compare_list_price)) if has_price_promo else 0"/>
                                <t t-set="variant_id" t-value="product.product_variant_id.id"/>
                                <t t-set="promo_type_val" t-value="product.promo_type or 'other'"/>

                                <!-- Libellés des types -->
                                <t t-set="promo_labels" t-value="{
                                    'pct':       ('fa-percent',  'badge-promo-pct',       'Remise'),
                                    'bogo':      ('fa-gift',     'badge-promo-bogo',      '1 acheté = 1 offert'),
                                    'bundle':    ('fa-archive',  'badge-promo-bundle',    'Pack / Bundle'),
                                    'qty':       ('fa-cubes',    'badge-promo-qty',       'Remise quantité'),
                                    'free_ship': ('fa-truck',    'badge-promo-free_ship', 'Livraison gratuite'),
                                    'other':     ('fa-tag',      'badge-promo-other',     'Promotion'),
                                }"/>
                                <t t-set="label_data" t-value="promo_labels.get(promo_type_val, promo_labels['other'])"/>

                                <div class="col-6 col-md-4 col-xl-3 promo-product-col"
                                     t-att-data-promo-type="promo_type_val">
                                    <div class="emakhc-promo-card">

                                        <!-- Badge absolu en haut à gauche -->
                                        <div class="badge-abs">
                                            <span t-attf-class="badge-promo-type #{label_data[1]}">
                                                <i t-attf-class="fa #{label_data[0]}"/>
                                                <t t-if="has_price_promo and promo_type_val == 'pct'">
                                                    -<t t-esc="discount"/>%
                                                </t>
                                                <t t-else="">
                                                    <t t-esc="label_data[2]"/>
                                                </t>
                                            </span>
                                        </div>

                                        <!-- Image (non cliquable) -->
                                        <div class="d-block" style="cursor: default;">
                                            <img t-attf-src="/web/image/product.template/#{product.id}/image_512"
                                                 class="product-img"
                                                 alt="produit"
                                                 loading="lazy"
                                                 onerror="this.src='/web/static/img/placeholder.png'"/>
                                        </div>

                                        <!-- Ruban description promo -->
                                        <div t-if="product.promo_description" class="text-center px-2 pb-1">
                                            <span class="promo-ribbon">
                                                <i class="fa fa-star me-1"/>
                                                <t t-esc="product.promo_description"/>
                                            </span>
                                        </div>

                                        <!-- Infos -->
                                        <div class="px-3 pb-3 d-flex flex-column flex-grow-1">
                                            <!-- Nom (non cliquable) -->
                                            <h6 class="fw-semibold text-dark mb-2" style="font-size: 0.88rem; line-height: 1.3; min-height: 36px;"
                                                t-field="product.name"/>

                                            <!-- Prix -->
                                            <div class="mb-3 mt-auto">
                                                <span class="fw-bold" style="color: #2E7D32; font-size: 1.05rem;"
                                                      t-field="product.list_price"
                                                      t-options="{'widget': 'monetary', 'display_currency': product.currency_id}"/>
                                                <span t-if="has_price_promo" class="ms-2 text-muted text-decoration-line-through" style="font-size: 0.82rem;"
                                                      t-field="product.compare_list_price"
                                                      t-options="{'widget': 'monetary', 'display_currency': product.currency_id}"/>
                                            </div>

                                            <!-- Stock -->
                                            <t t-set="stock_qty" t-value="int(product.sudo().qty_available)"/>
                                            <div class="mb-2 fw-bold" style="color: #CC0000; font-size: 0.82rem;">
                                                En stock : <t t-esc="stock_qty"/>
                                            </div>

                                            <!-- Action panier -->
                                            <div class="promo-cart-wrap">
                                                <button class="btn-add-promo" t-att-data-product-id="variant_id">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
                                                    Ajouter au panier
                                                </button>
                                                <div class="qty-selector-promo" data-qty="0">
                                                    <button class="qty-btn-promo qty-minus-promo" type="button">−</button>
                                                    <span class="qty-display-promo">1</span>
                                                    <button class="qty-btn-promo qty-plus-promo" type="button">+</button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </t>
                        </div>
                    </t>

                    <!-- Aucune promo -->
                    <t t-else="">
                        <div class="text-center py-5">
                            <i class="fa fa-tag text-muted" style="font-size: 4rem; opacity: 0.3;"/>
                            <h5 class="fw-semibold text-muted mt-3">Aucune promotion disponible pour le moment</h5>
                            <p class="text-muted mb-3">Revenez bientôt pour découvrir nos offres spéciales !</p>
                            <a href="/produits" class="btn text-white px-4" style="background-color: #2E7D32; border-radius: 8px;">
                                Voir tous les produits
                            </a>
                        </div>
                    </t>

                </div>
            </div>
        </t>
    </template>

</odoo>
