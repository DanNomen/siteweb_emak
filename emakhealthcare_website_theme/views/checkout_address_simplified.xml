<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="address_simplified" inherit_id="website_sale.address" name="Simplified Address Form">
        <!-- Hide Company Name and VAT -->
        <xpath expr="//div[@id='company_name_div']" position="attributes">
            <attribute name="class" separator=" " add="d-none"/>
        </xpath>
        <xpath expr="//div[@id='div_vat']" position="attributes">
            <attribute name="class" separator=" " add="d-none"/>
        </xpath>
        
        <!-- Hide Street 2 -->
        <xpath expr="//div[@id='div_street2']" position="attributes">
            <attribute name="class" separator=" " add="d-none"/>
        </xpath>

        <!-- Hide City -->
        <xpath expr="//div[@id='div_city']" position="attributes">
            <attribute name="class" separator=" " add="d-none"/>
        </xpath>

        <!-- Hide Zip (both occurrences) -->
        <xpath expr="//t[@t-if='zip_before_city']/div[@id='div_zip']" position="attributes">
            <attribute name="class" separator=" " add="d-none"/>
        </xpath>
        <xpath expr="//t[@t-if='not zip_before_city']/div[@id='div_zip']" position="attributes">
            <attribute name="class" separator=" " add="d-none"/>
        </xpath>

        <!-- Hide Country and State -->
        <xpath expr="//div[@id='div_country']" position="attributes">
            <attribute name="class" separator=" " add="d-none"/>
        </xpath>
        <xpath expr="//div[@id='div_state']" position="attributes">
            <attribute name="class" separator=" " add="d-none"/>
        </xpath>

        <!-- Rename "Street and Number" → "Adresse de livraison" -->
        <xpath expr="//div[@id='div_street']/label" position="replace">
            <label class="col-form-label" for="o_street">Adresse de livraison</label>
        </xpath>

        <!-- Move "Se connecter" block to its own line (below email input, not float-end) -->
        <xpath expr="//div[@id='div_email_public']/div[contains(@class,'float-end')]" position="replace">
            <div t-if="website.account_on_checkout != 'disabled'"
                 class="d-flex align-items-center gap-2 mt-2 mb-1">
                <span class="text-muted" style="font-size: 0.9rem;">Vous avez déjà un compte ?</span>
                <a role="button"
                   href="/web/login?redirect=/shop/checkout"
                   class="btn btn-primary btn-sm">
                    Se connecter
                </a>
            </div>
        </xpath>

        <!-- Change "Continue checkout" button text → "Valider la commande" -->
        <xpath expr="//button[@id='save_address']/t[@t-if='is_anonymous_cart']" position="replace">
            <t t-if="is_anonymous_cart">Valider la commande</t>
        </xpath>
    </template>
</odoo>
