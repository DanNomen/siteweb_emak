<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="address_simplified" inherit_id="website_sale.address" name="Simplified Address Form">
        <!-- Hide Company Name and VAT -->
        <xpath expr="//div[@id='company_name_div']" position="attributes">
            <attribute name="class" separator=" " add="d-none"/>
        </xpath>
        <xpath expr="//div[@id='div_vat']" position="attributes">
            <attribute name="class" separator=" " add="d-none"/>
        </xpath>
        
        <!-- Hide Street 2 -->
        <xpath expr="//div[@id='div_street2']" position="attributes">
            <attribute name="class" separator=" " add="d-none"/>
        </xpath>

        <!-- Hide City -->
        <xpath expr="//div[@id='div_city']" position="attributes">
            <attribute name="class" separator=" " add="d-none"/>
        </xpath>

        <!-- Hide Zip (both occurrences) -->
        <xpath expr="//t[@t-if='zip_before_city']/div[@id='div_zip']" position="attributes">
            <attribute name="class" separator=" " add="d-none"/>
        </xpath>
        <xpath expr="//t[@t-if='not zip_before_city']/div[@id='div_zip']" position="attributes">
            <attribute name="class" separator=" " add="d-none"/>
        </xpath>

        <!-- Hide Country and State -->
        <xpath expr="//div[@id='div_country']" position="attributes">
            <attribute name="class" separator=" " add="d-none"/>
        </xpath>
        <xpath expr="//div[@id='div_state']" position="attributes">
            <attribute name="class" separator=" " add="d-none"/>
        </xpath>
    </template>
</odoo>
