<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Surcharge de la page "Contactez-nous" pour le site Emakhealthcare.
        Hérite de website.contactus (odoo/addons/website/data/website_data.xml).
        On remplace uniquement :
          1. Le texte d'introduction
          2. La section "Ma Société" (h5 + liste ul) : téléphone + email seulement,
             adresse supprimée pour éviter tout espace vide disgracieux.
    -->
    <template id="contactus_emakhealthcare"
              name="Emakhealthcare – Page Contact personnalisée"
              inherit_id="website.contactus">

        <!-- 1. Remplacement du texte d'introduction -->
        <xpath expr="//p[hasclass('lead')]" position="replace">
            <p class="lead">
                Votre satisfaction est notre priorité.<br/>
                Écrivez-nous, nous revenons vers vous rapidement.
            </p>
        </xpath>

        <!-- 2. Remplacement complet de la colonne "Ma Société"
                (h5 + ul : on supprime la ligne adresse, on met nos vraies coordonnées) -->
        <xpath expr="//div[hasclass('col-lg-4')]" position="replace">
            <div class="col-lg-4 offset-lg-1 mt-4 mt-lg-0">
                <h5>Ma Société</h5>
                <ul class="list-unstyled mb-0 ps-2">
                    <li>
                        <i class="fa fa-phone fa-fw me-2"/>
                        <span class="o_force_ltr">+223 20 23 18 18</span>
                    </li>
                    <li>
                        <i class="fa fa-1x fa-fw fa-envelope me-2"/>
                        <span>info@emak-mali.com</span>
                    </li>
                </ul>

                <!-- Bouton WhatsApp supprimé à la demande de l'utilisateur -->
            </div>
        </xpath>

    </template>
</odoo>
