<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_product_promo_wizard_form" model="ir.ui.view">
        <field name="name">product.promo.wizard.form</field>
        <field name="model">product.promo.wizard</field>
        <field name="arch" type="xml">
            <form string="Mettre en Promotion">
                <sheet>
                    <group>
                        <field name="promo_type" widget="selection"/>
                        <field name="promo_description" invisible="promo_type == 'none'"/>
                    </group>
                    <group>
                        <!-- Les articles sélectionnés -->
                        <field name="product_ids" widget="many2many_tags" invisible="not product_ids"/>
                        <field name="product_tmpl_ids" widget="many2many_tags" invisible="not product_tmpl_ids"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_apply_promo" string="Appliquer" type="object" class="btn-primary"/>
                    <button string="Annuler" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action pour product.product -->
    <record id="action_product_promo_wizard_product" model="ir.actions.act_window">
        <field name="name">Mettre en Promotion</field>
        <field name="res_model">product.promo.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="product.model_product_product"/>
        <field name="binding_view_types">list,form</field>
    </record>

    <!-- Action pour product.template -->
    <record id="action_product_promo_wizard_template" model="ir.actions.act_window">
        <field name="name">Mettre en Promotion</field>
        <field name="res_model">product.promo.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="product.model_product_template"/>
        <field name="binding_view_types">list,form</field>
    </record>
</odoo>
