<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_recap_promos_wizard_form" model="ir.ui.view">
        <field name="name">recap.promos.wizard.form</field>
        <field name="model">recap.promos.wizard</field>
        <field name="arch" type="xml">
            <form string="Récapitulatif des Promotions">
                <group>
                    <field name="start_date"/>
                    <field name="end_date"/>
                </group>
                <footer>
                    <button string="Générer le rapport" name="action_print_report" type="object" class="btn-primary"/>
                    <button string="Annuler" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_recap_promos_wizard" model="ir.actions.act_window">
        <field name="name">Récapitulatif des Promotions</field>
        <field name="res_model">recap.promos.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="recap_promos_menu"
              name="Récapitulatif des Promotions"
              action="action_recap_promos_wizard"
              parent="sale.menu_sale_report"
              sequence="20"/>
</odoo>
