<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Vue Form -->
    <record id="view_claim_reclamation_form" model="ir.ui.view">
        <field name="name">claim.reclamation.form</field>
        <field name="model">claim.reclamation</field>
        <field name="arch" type="xml">
            <form string="Réclamation">
                <header>
                    <button name="action_close" string="Clôturer" type="object" invisible="state != 'draft'" class="btn-primary"/>
                    <button name="action_draft" string="Réouvrir" type="object" invisible="state == 'draft'" class="btn-primary"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,closed"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <h1>
                                <field name="name_sequence" />
                            </h1>
                            <field name="name"/>
                            <field name="message"/>
                            <field name="user_id"/>
                            <field name="source" widget="radio"/>
                            <field name="claim_date"/>
                            <field name="close_date"/>
                            <field name="all_reasons" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Lignes">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="product_id"/>
                                    <field name="reason"/>
                                    <field name="quantity"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Vue List -->
    <record id="view_claim_reclamation_list" model="ir.ui.view">
        <field name="name">claim.reclamation.list</field>
        <field name="model">claim.reclamation</field>
        <field name="arch" type="xml">
            <list>
                <field name="name_sequence" />
                <field name="name"/>
                <field name="user_id"/>
                <field name="source"/>
                <field name="claim_date"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- Vue Search -->
    <record id="view_claim_reclamation_search" model="ir.ui.view">
        <field name="name">claim.reclamation.search</field>
        <field name="model">claim.reclamation</field>
        <field name="arch" type="xml">
            <search string="Rechercher Réclamations">
                <field name="name_sequence"/>
                <field name="name"/>
                <field name="user_id"/>
                
                <filter string="Brouillon" name="filter_draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Fermé" name="filter_closed" domain="[('state', '=', 'closed')]"/>
                
                <separator/>
                
                <filter string="Normal" name="filter_normal" domain="[('source', '=', 'normal')]"/>
                <filter string="Extranet / Site Web" name="filter_extranet" domain="[('source', '=', 'extranet')]"/>
                
                <group expand="0" string="Grouper par">
                    <filter string="Source" name="group_source" context="{'group_by': 'source'}"/>
                    <filter string="État" name="group_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_claim_reclamation" model="ir.actions.act_window">
        <field name="name">Réclamations</field>
        <field name="res_model">claim.reclamation</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_claim_reclamation_search"/>
        <field name="domain">[]</field>
        <field name="context">{'create': 1, 'delete': 1, 'edit': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Réclamations
            </p>
        </field>
    </record>

    <!-- Menu principal -->
    <menuitem 
        id="menu_claim_root"
        name="Réclamations"
        sequence="10"
        web_icon="website_emakmed,static/img/icon.png"/>

    <!-- Sous-menu Réclamations -->
    <menuitem 
        id="menu_claim_reclamation"
        name="Réclamations"
        parent="menu_claim_root"
        action="action_claim_reclamation"/>
</odoo>