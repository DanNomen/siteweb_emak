<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <template id="custom_footer_dynamic" inherit_id="website.layout">
    <xpath expr="//footer" position="replace">
      <footer id="bottom" class="o_footer o_colored_level o_cc">
        <style>
          @media (max-width: 767.98px) {
              #bottom.o_footer {
                  display: block !important;
              }
          }
        </style>
        <style>
          /* Supprimer l'espace entre le contenu principal et le footer */
          #wrapwrap > main { padding-bottom: 0 !important; margin-bottom: 0 !important; }
          #wrapwrap { padding-bottom: 0 !important; }
          .o_footer { margin-top: 0 !important; }
          #bottom.o_footer .s_text_block { margin-top: 0 !important; padding-top: 0 !important; }
          #bottom.o_footer .s_text_block > .container { padding-top: 8px !important; padding-bottom: 4px !important; }
          /* Supprimer les vagues / shape dividers Odoo dans le footer */
          #bottom.o_footer .o_we_shape,
          #bottom.o_footer .s_text_block > .o_we_shape,
          #bottom.o_footer section::before,
          #bottom.o_footer section::after,
          #bottom.o_footer .s_text_block::before,
          #bottom.o_footer .s_text_block::after { display: none !important; height: 0 !important; }
        </style>
        <section class="s_text_block py-0 m-0">
          <div class="container">
            <div class="row">
              
              <!-- 🌐 Liens utiles -->
              <div class="col-lg-2 pt24 pb24">
                <h5 class="mb-3">Liens utiles</h5>
                <ul class="list-unstyled">
                  <li><a href="/">Accueil</a></li>
                  <li><a href="/aboutus">À propos de nous</a></li>
                  <li><a href="/shop">Produits</a></li>
                  <li><a href="/contactus">Services</a></li>
                  <li><a href="/legal">Mentions légales</a></li>
                  <li><a href="/contactus">Contactez-nous</a></li>
                </ul>
              </div>

              <!-- 🏢 À propos -->
              <div class="col-lg-5 px-3 py-1">
                <h5 class="mb-1 mt-2">À propos de nous</h5>
                <p class="mb-1">
                  Nous sommes une équipe de passionnés dédiée à offrir des produits innovants pour améliorer la vie de chacun.
                </p>
                <p class="mb-1">
                  Nos produits sont conçus pour les petites et moyennes entreprises désireuses d’optimiser leurs performances.
                </p>
              </div>

              <!-- 📞 Contact & Réseaux -->
              <div id="connect" class="col-lg-4 offset-lg-1 px-3 py-1">
                <h5 class="mb-1 mt-2">Rejoignez-nous</h5>
                <ul class="list-unstyled mb-0">
                  <li>
                    <i class="fa fa-comment fa-fw me-2"></i>
                    <a href="/contactus">Contactez-nous</a>
                  </li>
                  <li>
                    <i class="fa fa-envelope fa-fw me-2"></i>
                    <a t-att-href="'mailto:%s' % website.company_id.email">
                      <t t-esc="website.company_id.email or 'info@yourcompany.com'"/>
                    </a>
                  </li>
                  <li>
                    <i class="fa fa-phone fa-fw me-2"></i>
                    <a t-att-href="'tel:%s' % website.company_id.phone">
                      <t t-esc="website.company_id.phone or '+261 00 000 0000'"/>
                    </a>
                  </li>
                </ul>

              </div>
            </div>
          </div>
        </section>

        <!-- 🔒 COPYRIGHT -->
        <div class="o_footer_copyright o_colored_level o_cc">
          <div class="container py-1">
            <div class="row">
              <div class="col-sm text-center text-sm-start text-muted">
                <span>
                  © <t t-esc="website.company_id.name or 'Nom de l’entreprise'"/> - 
                  <t t-esc="datetime.datetime.now().year"/>
                </span>
              </div>
              <div class="col-sm text-center text-sm-end text-muted">
                <span>Développé avec ❤️ par <a href="/">Dagodoo</a></span>
              </div>
            </div>
          </div>
        </div>
      </footer>
    </xpath>
  </template>
</odoo>
