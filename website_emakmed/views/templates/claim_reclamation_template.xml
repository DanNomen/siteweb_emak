<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="claim_reclamation_template" >
        <t t-call="website.layout">
            <div class="container py-5">
                <h2 class="o_cc o_cc1 text-center rounded-1 shadow-sm claim-hero-title" style="background: linear-gradient(90deg, #38A935, #93C123); color: white; padding: 60px">
                    Créer une réclamation
                </h2>
                <div class="shadow p-4 my-5 bg-body rounded-3">
                    <form id="reclamationForm" action="/submit/claim" method="post">
                        <div class="form-group mb-3">
                            <label for="invoice_number">Numéro de Facture</label>
                            <input class="form-control" type="text" id="invoice_number" name="invoice_number"/>
                            <span id="invoice_number_error" class="text-center" style="color: red"></span>
                        </div>
                        <div class="text-center">
                            <button id="find_invoice_btn" class="btn btn-primary" type="button">Trouver la Facture
                            </button>
                        </div>

                        <!-- Les produits de la facture sont affichés sous forme de cartes sur mobile -->
                        <div class="form-group mt-4" id="claim_table" style="display:none;">
                            <div class="purchase_tbody"></div>
                        </div>

                        <!-- Champ de message qui apparaît après la récupération des produits -->
                        <div class="form-group mb-3" id="message_field" style="display:none;">
                            <label for="message">Message</label>
                            <textarea class="form-control" id="message" name="message"></textarea>
                        </div>

                        <!-- Bouton de soumission, masqué jusqu'à ce que la facture soit trouvée -->
                        <div class="text-center">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/> 
                            <button class="btn btn-primary" type="submit" id="submit_btn" style="display:none;">Valider la reclamation</button>
                        </div>
                    </form>
                </div>
            </div>

        </t>
    </template>

    <template id="reclamation_thankyou">
        <t t-call="website.layout">
            <div class="container py-5">
                <h2 class="o_cc o_cc1 text-center rounded-1 shadow-sm claim-hero-title" 
                    style="background: linear-gradient(90deg, #38A935, #93C123); color: white; padding: 60px">
                    Réclamation créée avec succès
                </h2>
                <div class="shadow p-4 my-5 bg-body rounded-3 text-center">
                    <h4 class="text-success fw-bold mb-3">
                        🎉 Merci pour votre réclamation !
                    </h4>
                    <p class="fs-5 text-muted">
                        Votre réclamation a bien été enregistrée.
                    </p>
                    <a href="/" class="btn btn-primary mt-3">
                        <i class="fa fa-home"></i> Retour à l'accueil
                    </a>
                </div>
            </div>
        </t>
    </template>

    <template id="claim_reclamation_list_template">
        <t t-call="website.layout">
            <div class="container py-5">
                <h2 class="o_cc o_cc1 text-center rounded-1 shadow-sm claim-hero-title" style="background: linear-gradient(90deg, #38A935, #93C123); color: white; padding: 60px">
                    Vos réclamations
                </h2>

                <div class="mb-4 pb-5">
                    <a href="/claim/create" class="btn w-100 fw-bold py-3"
                       style="background: linear-gradient(90deg, #38A935, #93C123); color: white; border-radius: 10px; font-size: 1.1rem; box-shadow: 0 4px 12px rgba(56,169,53,0.3);">
                        <i class="fa fa-plus-circle me-2"></i> Créer une réclamation
                    </a>
                </div>

                <t t-if="claims">
                    <div class="accordion" id="claimsAccordion">
                            <t t-foreach="claims" t-as="claim" t-key="claim.id">
                                <div class="accordion-item claim-card mb-3 border-0">
                                    <h4 class="accordion-header d-flex align-items-center" t-attf-id="heading#{claim.id}">
                                        <button
                                            class="accordion-button collapsed fw-semibold flex-grow-1 claim-card-header"
                                            type="button" data-bs-toggle="collapse"
                                            t-attf-data-bs-target="#collapse#{claim.id}"
                                            aria-expanded="false"
                                            t-attf-aria-controls="collapse#{claim.id}">
                                            <div class="d-flex align-items-center gap-2">
                                                <i class="fa fa-file-invoice text-success"></i>
                                                <div class="d-flex flex-column">
                                                    <strong><t t-esc="claim.name_sequence"/></strong>
                                                    <small class="text-muted">
                                                        <t t-if="claim.claim_date" t-esc="claim.claim_date.strftime('%d/%m/%Y')"/>
                                                    </small>
                                                </div>
                                            </div>
                                        </button>
                                        <a t-att-href="'/claim/your_claims/%s' % claim.id"
                                           class="btn btn-outline-primary btn-sm mx-2 claim-action-btn"
                                           title="Voir le détail">
                                            <i class="fa fa-eye"></i>
                                        </a>
                                    </h4>
                                    <div t-attf-id="collapse#{claim.id}"
                                         class="accordion-collapse collapse"
                                         t-attf-aria-labelledby="heading#{claim.id}"
                                         data-bs-parent="#claimsAccordion">
                                        <div class="accordion-body claim-card-body">
                                            <div class="claim-info-row">
                                                <span class="label">N° de Facture</span>
                                                <span class="value"><t t-esc="claim.name"/></span>
                                            </div>
                                            <div class="claim-info-row">
                                                <span class="label">Date de création</span>
                                                <span class="value">
                                                    <t t-if="claim.claim_date" t-esc="claim.claim_date.strftime('%d/%m/%Y %H:%M')"/>
                                                </span>
                                            </div>
                                            <div class="claim-info-row">
                                                <span class="label">Statut</span>
                                                <span class="value">
                                                    <t t-if="claim.state == 'draft'">
                                                        <span class="badge text-bg-secondary">En attente</span>
                                                    </t>
                                                    <t t-elif="claim.state == 'closed'">
                                                        <span class="badge text-bg-success">Cloturée</span>
                                                    </t>
                                                </span>
                                            </div>
                                            <div class="claim-info-row">
                                                <span class="label">Date clôture</span>
                                                <span class="value">
                                                    <t t-if="claim.close_date" t-esc="claim.close_date.strftime('%d/%m/%Y %H:%M')"/>
                                                    <t t-else="">—</t>
                                                </span>
                                            </div>

                                            <div class="text-center mt-3">
                                                <a t-att-href="'/claim/your_claims/%s' % claim.id"
                                                   class="btn btn-primary btn-sm w-100">
                                                    <i class="fa fa-eye"></i> Voir le détail
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </t>
                    </div>
                </t>

                <t t-else="">
                    <div class="alert alert-info text-center mt-5">
                        <i class="fa fa-info-circle"></i> Aucune réclamation n’a été trouvée.
                    </div>
                </t>
            </div>
        </t>
    </template>

    <template id="claim_detail_template">
        <t t-call="website.layout">
            <div class="container py-5">

                <!-- Bouton retour -->
                <div class="text-start mb-5">
                    <a href="/claim/your_claims" class="btn btn-outline-primary">
                        ← Retour à la liste des réclamations
                    </a>
                </div>
                
                <h2 class="text-center rounded-1 shadow-sm mb-5 claim-hero-title" 
                    style="background: linear-gradient(90deg, #38A935, #93C123); color: white; padding: 60px;">
                    Vos réclamations
                </h2>

                <t t-if="claim">
                    <!-- Informations de la réclamation -->
                    <div class="claim-card mb-4">
                        <div class="claim-card-body p-4">
                            <h4 class="mb-3">Informations de la réclamation</h4>
                            <div class="claim-info-row">
                                <span class="label">N° de Réclamation</span>
                                <span class="value"><t t-esc="claim.name_sequence"/></span>
                            </div>
                            <div class="claim-info-row">
                                <span class="label">Date de création</span>
                                <span class="value">
                                    <t t-if="claim.claim_date" t-esc="claim.claim_date.strftime('%d/%m/%Y %H:%M')"/>
                                </span>
                            </div>
                            <div class="claim-info-row">
                                <span class="label">N° de Facture</span>
                                <span class="value"><t t-esc="claim.name"/></span>
                            </div>
                            <div class="claim-info-row">
                                <span class="label">Date de clôture</span>
                                <span class="value">
                                    <t t-if="claim.close_date" t-esc="claim.close_date.strftime('%d/%m/%Y %H:%M')"/>
                                    <t t-else="">—</t>
                                </span>
                            </div>
                            <div class="claim-info-row">
                                <span class="label">Statut</span>
                                <span class="value">
                                    <t t-if="claim.state == 'draft'">
                                        <span class="badge text-bg-secondary">En attente</span>
                                    </t>
                                    <t t-elif="claim.state == 'closed'">
                                        <span class="badge text-bg-success">Cloturée</span>
                                    </t>
                                </span>
                            </div>
                            <div class="claim-info-row">
                                <span class="label">Motif</span>
                                <span class="value"><t t-esc="claim.all_reasons"/></span>
                            </div>
                        </div>
                    </div>

                    <!-- Détails des lignes de réclamation -->
                    <div class="claim-card mb-4">
                        <div class="claim-card-body p-4">
                            <h4 class="mb-3">Détails des produits réclamés</h4>
                            <t t-if="claim.line_ids">
                                <div class="table-responsive table-responsive-cards">
                                    <table class="table table-striped table-hover">
                                        <t t-foreach="claim.line_ids" t-as="line" t-key="line.id">
                                            <div class="claim-product-card mb-3">
                                                <div class="claim-info-row">
                                                    <span class="label">Produit</span>
                                                    <span class="value">
                                                        <t t-if="line.product_id">
                                                            <t t-esc="line.product_id.name"/>
                                                        </t>
                                                        <t t-else="">
                                                            <span class="text-muted">Produit non spécifié</span>
                                                        </t>
                                                    </span>
                                                </div>
                                                <div class="claim-info-row">
                                                    <span class="label">Motif de réclamation</span>
                                                    <span class="value">
                                                        <t t-if="line.reason_display">
                                                            <t t-esc="line.reason_display"/>
                                                        </t>
                                                        <t t-else="">
                                                            <span class="text-muted">-</span>
                                                        </t>
                                                    </span>
                                                </div>
                                                <div class="claim-info-row">
                                                    <span class="label">Quantité</span>
                                                    <span class="value"><t t-esc="line.quantity"/></span>
                                                </div>
                                            </div>
                                        </t>
                                    </table>
                                </div>
                            </t>
                            <t t-else="">
                                <div class="alert alert-info text-center">
                                    <i class="fa fa-info-circle"></i> Aucune ligne de réclamation trouvée.
                                </div>
                            </t>
                        </div>
                    </div>

                    <!-- Message de la réclamation -->
                    <div class="claim-card mb-4">
                        <div class="claim-card-body p-4">
                            <h4 class="mb-3">Votre message</h4>
                            <t t-if="claim.message">
                                <p class="mb-0"><t t-esc="claim.message"/></p>
                            </t>
                            <t t-else="">
                                <span class="text-muted">Aucun message</span>
                            </t>
                        </div>
                    </div>
                </t>
                <t t-else="">
                    <div class="alert alert-warning text-center">
                        <strong>Erreur :</strong> Réclamation introuvable ou non autorisée.
                    </div>
                </t>
            </div>
        </t>
    </template>

</odoo>
