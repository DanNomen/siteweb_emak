<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- 💰 FACTURES -->
    <template id="my_officine_invoices_template" name="Officine Invoices">
        <t t-call="website.layout">
            <div class="container py-5">
                <h2 class="text-center rounded-1 shadow-sm mb-5" 
                    style="background: linear-gradient(90deg, #38A935, #93C123); color: white; padding: 60px;">
                    Mes Factures
                </h2>

                <t t-if="invoices">
                    <div class="accordion shadow-sm rounded" id="invoiceAccordion">
                        <t t-foreach="invoices" t-as="invoice" t-key="invoice.id">
                            <div class="accordion-item mb-3 border-0 shadow-sm">
                                <h4 class="accordion-header" t-attf-id="heading#{invoice.id}">
                                    <button 
                                        class="accordion-button collapsed" 
                                        type="button" data-bs-toggle="collapse" 
                                        t-attf-data-bs-target="#collapse#{invoice.id}" 
                                        aria-expanded="false" 
                                        t-attf-aria-controls="collapse#{invoice.id}"
                                    >
                                        <div class="d-flex justify-content-between align-items-center w-100">
                                            <div class="d-flex flex-column">
                                                <strong><t t-esc="invoice.name or 'N/A'"/></strong>
                                                <small class="text-muted">
                                                    <t t-esc="invoice.invoice_date or '—'"/>
                                                </small>
                                            </div>
                                            <div style="margin-right: 10px;">
                                                <t 
                                                    t-set="state_labels" 
                                                    t-value="{
                                                        'draft': 'Brouillon',
                                                        'posted': 'Payé',
                                                        'cancel': 'Annulée'
                                                    }"
                                                />

                                                <span t-attf-class="badge rounded-pill 
                                                    #{'bg-success' if invoice.state == 'posted' else 
                                                    'bg-warning' if invoice.state == 'draft' else 
                                                    'bg-danger'}">
                                                    <t t-esc="state_labels.get(invoice.state, invoice.state)"/>
                                                </span>
                                            </div>
                                        </div>
                                    </button>
                                </h4>
                                <div t-attf-id="collapse#{invoice.id}" 
                                    class="accordion-collapse collapse" 
                                    t-attf-aria-labelledby="heading#{invoice.id}" 
                                    data-bs-parent="#invoiceAccordion">
                                    <div class="accordion-body bg-light">
                                        <div class="d-flex justify-content-between align-items-center mb-3">
                                            <div>
                                                <strong>Total HT :</strong> 
                                                <t t-out="invoice.amount_untaxed" t-options="{'widget': 'monetary', 'display_currency': invoice.currency_id}"/>
                                                <br/>

                                                <strong>Total Ristourne :</strong>
                                                <t t-out="invoice.total_ristourne" t-options="{'widget': 'monetary', 'display_currency': invoice.currency_id}"/>
                                                <br/>

                                                <strong>Total Escompte :</strong>
                                                <t t-out="invoice.total_escompte" t-options="{'widget': 'monetary', 'display_currency': invoice.currency_id}"/>
                                                <br/>

                                                <strong>T.V.A. :</strong> 
                                                <t t-out="invoice.amount_tax" t-options="{'widget': 'monetary', 'display_currency': invoice.currency_id}"/>
                                                <br/>
                                            </div>

                                            <a t-attf-href="/report/pdf/account.report_invoice/#{invoice.id}"
                                            class="btn btn-outline-primary btn-md" target="_blank">
                                                <i class="fa fa-download"></i> Télécharger PDF
                                            </a>
                                        </div>

                                        <!-- Liste des articles publiés -->
                                        <t t-set="published_lines" t-value="invoice.invoice_line_ids.filtered(lambda l: l.product_id.is_published)"/>
                                        <t t-if="published_lines">
                                            <div class="table-responsive">
                                                <table class="table table-sm table-hover align-middle bg-white rounded">
                                                    <thead class="table-primary">
                                                        <tr>
                                                            <th>Article</th>
                                                            <th>Quantité</th>
                                                            <th>Prix Unitaire</th>
                                                            <th>Escompte</th>
                                                            <th>Ristourne</th>
                                                            <th>Sous-total</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        <t t-foreach="published_lines" t-as="line" t-key="line.id">
                                                            <tr>
                                                                <td><t t-esc="line.product_id.name"/></td>
                                                                <td><t t-esc="line.quantity"/></td>
                                                                <td>
                                                                    <t t-out="line.price_unit" t-options="{'widget': 'monetary', 'display_currency': invoice.currency_id}"/>
                                                                </td>
                                                                <td>
                                                                    <t t-out="line.escompte" t-options="{'widget': 'monetary', 'display_currency': invoice.currency_id}"/>
                                                                </td>
                                                                <td>
                                                                    <t t-out="line.ristourne" t-options="{'widget': 'monetary', 'display_currency': invoice.currency_id}"/>
                                                                </td>
                                                                <td>
                                                                    <t t-out="line.price_subtotal" t-options="{'widget': 'monetary', 'display_currency': invoice.currency_id}"/>
                                                                </td>
                                                            </tr>
                                                        </t>
                                                    </tbody>
                                                </table>
                                            </div>
                                        </t>
                                        <t t-else="">
                                            <div class="alert alert-warning mt-3">
                                                Aucun article publié pour cette facture.
                                            </div>
                                        </t>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </div>
                </t>
                <t t-else="">
                    <div class="alert alert-info text-center mt-5">
                        <i class="fa fa-info-circle"></i> Vous n'avez encore aucune facture.
                    </div>
                </t>
            </div>
        </t>
    </template>



   <template id="my_officine_credit_notes_template" name="Officine Credits">
