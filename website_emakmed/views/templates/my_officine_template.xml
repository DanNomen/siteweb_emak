                    Mes Avoirs
                </h2>

                <t t-if="credit_notes">
                    <div class="accordion shadow-sm rounded" id="creditNoteAccordion">
                        <t t-foreach="credit_notes" t-as="credit" t-key="credit.id">
                            <div class="accordion-item mb-3 border-0 shadow-sm">
                                <h4 class="accordion-header" t-attf-id="headingCredit#{credit.id}">
                                    <button 
                                        class="accordion-button collapsed" 
                                        type="button" data-bs-toggle="collapse" 
                                        t-attf-data-bs-target="#collapseCredit#{credit.id}" 
                                        aria-expanded="false" 
                                        t-attf-aria-controls="collapseCredit#{credit.id}"
                                    >
                                        <div class="d-flex justify-content-between align-items-center w-100">
                                            <div class="d-flex flex-column">
                                                <strong><t t-esc="credit.name or 'N/A'"/></strong>
                                                <small class="text-muted">
                                                    <t t-esc="credit.invoice_date or '—'"/>
                                                </small>
                                            </div>
                                            <div style="margin-right: 10px;">
                                                <t 
                                                    t-set="state_labels" 
                                                    t-value="{
                                                        'draft': 'Brouillon',
                                                        'posted': 'Payé',
                                                        'cancel': 'Annulée'
                                                    }"
                                                />

                                                <span t-attf-class="badge rounded-pill 
                                                    #{'bg-success' if credit.state == 'posted' else 
                                                    'bg-warning' if credit.state == 'draft' else 
                                                    'bg-danger'}">
                                                    <t t-esc="state_labels.get(credit.state, credit.state)"/>
                                                </span>
                                            </div>
                                        </div>
                                    </button>
                                </h4>
                                <div t-attf-id="collapseCredit#{credit.id}" 
                                    class="accordion-collapse collapse" 
                                    t-attf-aria-labelledby="headingCredit#{credit.id}" 
                                    data-bs-parent="#creditNoteAccordion">
                                    <div class="accordion-body bg-light">
                                        <div class="d-flex justify-content-between align-items-center mb-3">
                                            <div>
                                                <strong>Total HT :</strong> <t t-out="credit.amount_untaxed" t-options="{'widget': 'monetary', 'display_currency': credit.currency_id}"/> <br/>
                                                <strong>Total Ristourne :</strong> <t t-out="credit.total_ristourne" t-options="{'widget': 'monetary', 'display_currency': credit.currency_id}"/> <br/>
                                                <strong>Total Escompte :</strong> <t t-out="credit.total_escompte" t-options="{'widget': 'monetary', 'display_currency': credit.currency_id}"/> <br/>
                                                <strong>T.V.A. :</strong> <t t-out="credit.amount_tax" t-options="{'widget': 'monetary', 'display_currency': credit.currency_id}"/> <br/>
                                                <strong>Total TTC :</strong> <t t-out="credit.amount_total" t-options="{'widget': 'monetary', 'display_currency': credit.currency_id}"/> <br/>
                                            </div>
                                            <a t-attf-href="/report/pdf/account.report_invoice/#{credit.id}"
                                            class="btn btn-outline-primary btn-md" target="_blank">
                                                <i class="fa fa-download"></i> Télécharger PDF
                                            </a>
                                        </div>

                                        <!-- Liste des articles publiés -->
                                        <t t-set="published_lines" t-value="credit.invoice_line_ids.filtered(lambda l: l.product_id.is_published)"/>
                                        <t t-if="published_lines">
                                            <div class="table-responsive">
                                                <table class="table table-sm table-hover align-middle bg-white rounded">
                                                    <thead class="table-success">
                                                        <tr>
                                                            <th>Article</th>
                                                            <th>Quantité</th>
                                                            <th>Prix Unitaire</th>
                                                            <th>Escompte</th>
                                                            <th>Ristourne</th>
                                                            <th>Sous-total</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        <t t-foreach="published_lines" t-as="line" t-key="line.id">
                                                            <tr>
                                                                <td><t t-esc="line.product_id.name"/></td>
                                                                <td><t t-esc="line.quantity"/></td>
                                                                <td><t t-out="line.price_unit" t-options="{'widget': 'monetary', 'display_currency': credit.currency_id}"/> </td>
                                                                <td><t t-out="line.escompte" t-options="{'widget': 'monetary', 'display_currency': credit.currency_id}"/> </td>
                                                                <td><t t-out="line.ristourne" t-options="{'widget': 'monetary', 'display_currency': credit.currency_id}"/> </td>
                                                                <td><t t-out="line.price_subtotal" t-options="{'widget': 'monetary', 'display_currency': credit.currency_id}"/> </td>
                                                            </tr>
                                                        </t>
                                                    </tbody>
                                                </table>
                                            </div>
                                        </t>
                                        <t t-else="">
                                            <div class="alert alert-warning mt-3">
                                                Aucun article publié pour cet avoir.
                                            </div>
                                        </t>
                                    </div>
                                </div>
                            </div>
