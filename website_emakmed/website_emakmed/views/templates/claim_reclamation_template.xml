<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="claim_reclamation_template" >
        <t t-call="website.layout">
            <div class="container py-5">
                <h2 class="o_cc o_cc1 text-center rounded-1 shadow-sm" style="background: linear-gradient(90deg, #38A935, #93C123); color: white; padding: 60px">
                    Créer une réclamation
                </h2>
                <div class="table-responsive">
                    <div class="shadow p-4 my-5 bg-body rounded-3">
                        <form id="reclamationForm" action="/submit/claim" method="post">
                            <div class="form-group mb-3">
                                <label for="invoice_number">Numéro de Facture</label>
                                <input class="form-control" type="text" id="invoice_number" name="invoice_number"/>
                                <span id="invoice_number_error" class="text-center" style="color: red"></span>
                            </div>
                            <div class="text-center">
                                <button id="find_invoice_btn" class="btn btn-primary" type="button">Trouver la Facture
                                </button>
                            </div>
                            
                            <div class="form-group mt-3">
                                <table class="table table-striped table-hover d-none" id="claim_table">
                                    <thead class="table-light"> 
                                        <tr>
                                            <th class="text-start">Selectioner</th>
                                            <th class="text-start">Products</th>
                                            <th class="text-start"> Motif de la réclamation </th>
                                            <th class="text-start">Quantité</th>
                                        </tr>
                                    </thead>
                                    <tbody class="purchase_tbody">
                                    </tbody>
                                </table>
                            </div>

                            <!-- Champ de message qui apparaît après la récupération des produits -->
                            <div class="form-group mb-3" id="message_field" style="display:none;">
                                <label for="message">Message</label>
                                <textarea class="form-control" id="message" name="message"></textarea>
                            </div>

                            <!-- Bouton de soumission, masqué jusqu'à ce que la facture soit trouvée -->
                            <div class="text-center">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/> 
                                <button class="btn btn-primary" type="submit" id="submit_btn" style="display:none;">Valider la reclamation</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

        </t>
    </template>

    <template id="reclamation_thankyou">
        <t t-call="website.layout">
            <div class="container py-5">
                <h2 class="o_cc o_cc1 text-center rounded-1 shadow-sm" 
                    style="background: linear-gradient(90deg, #38A935, #93C123); color: white; padding: 60px">
                    Réclamation créée avec succès
                </h2>
                <div class="table-responsive">
                    <div class="shadow p-4 my-5 bg-body rounded-3 text-center">
                        <h4 class="text-success fw-bold mb-3">
                            🎉 Merci pour votre réclamation !
                        </h4>
                        <p class="fs-5 text-muted">
                            Votre réclamation a bien été enregistrée.
                        </p>
                        <a href="/" class="btn btn-primary mt-3">
                            <i class="fa fa-home"></i> Retour à l'accueil
                        </a>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <template id="claim_reclamation_list_template">
        <t t-call="website.layout">
            <div class="container py-5">
                <h2 class="o_cc o_cc1 text-center rounded-1 shadow-sm" style="background: linear-gradient(90deg, #38A935, #93C123); color: white; padding: 60px">
                    Vos réclamations
                </h2>

                <div class="mb-4 pb-5">
                    <a href="/claim/create" class="btn w-100 fw-bold py-3"
                       style="background: linear-gradient(90deg, #38A935, #93C123); color: white; border-radius: 10px; font-size: 1.1rem; box-shadow: 0 4px 12px rgba(56,169,53,0.3);">
                        <i class="fa fa-plus-circle me-2"></i> Créer une réclamation
                    </a>
                </div>

                <t t-if="claims">
                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead class="table-light">
                                <tr>
                                    <th>N° de Réclamation</th>
                                    <th>Date de création</th>
                                    <th>N° de Facture</th>
                                    <th>Statut</th>
                                    <th>Date clôture</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="claims" t-as="claim">
                                    <tr>
                                        <td><t t-esc="claim.name_sequence"/></td>
                                        <td><t t-if="claim.claim_date" t-esc="claim.claim_date.strftime('%d/%m/%Y %H:%M')"/></td>
                                        <td><t t-esc="claim.name"/></td>
                                        <td>
                                            <t t-if="claim.state == 'draft'">
                                                <span class="badge text-bg-secondary">En attente</span>
                                            </t>
                                            <t t-elif="claim.state == 'closed'">
                                                <span class="badge text-bg-success">Cloturée</span>
                                            </t>                                      
                                        </td>
                                        <td><t t-if="claim.close_date" t-esc="claim.close_date.strftime('%d/%m/%Y %H:%M')"/></td>
                                        <td class="text-end">
                                            <a t-att-href="'/claim/your_claims/%s' % claim.id"
                                            class="btn btn-primary btn-md">
                                                Voir détail
                                            </a>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </t>

                <t t-else="">
                    <div class="alert alert-info text-center mt-5">
                        <i class="fa fa-info-circle"></i> Aucune réclamation n’a été trouvée.
                    </div>
                </t>
            </div>
        </t>
    </template>

    <template id="claim_detail_template">
        <t t-call="website.layout">
            <div class="container py-5">

                <!-- Bouton retour -->
                <div class="text-start mb-5">
                    <a href="/claim/your_claims" class="btn btn-outline-primary">
                        ← Retour à la liste des réclamations
                    </a>
                </div>
                
                <h2 class="text-center rounded-1 shadow-sm mb-5" 
                    style="background: linear-gradient(90deg, #38A935, #93C123); color: white; padding: 60px;">
                    Vos réclamations
                </h2>

                <t t-if="claim">
                    <!-- Informations de la réclamation -->
                    <div class="card shadow-sm mb-5">
                        <div class="card-body">
                            <h4 class="mb-4">Informations de la réclamation</h4>
                            <div class="row">
                                <div class="col-md-6">
                                    <div><strong>N° de Réclamation :</strong> <t t-esc="claim.name_sequence"/></div><br/>
                                    <div><strong>Date de création :</strong> <t t-if="claim.claim_date" t-esc="claim.claim_date.strftime('%d/%m/%Y %H:%M')"/></div><br/>
                                    <div><strong>N° de Facture	:</strong> <t t-esc="claim.name"/></div><br/>
                                    <div><strong> Date de clôture :</strong> <t t-if="claim.close_date" t-esc="claim.close_date.strftime('%d/%m/%Y %H:%M')"/></div>
                                </div>
                                <div class="col-md-6">
                                    <div><strong>Statut :</strong>
                                        <t t-if="claim.state == 'draft'">
                                            <span class="badge text-bg-secondary">En attente</span>
                                        </t>
                                        <t t-elif="claim.state == 'closed'">
                                            <span class="badge text-bg-success">Cloturée</span>
                                        </t>        
                                    </div><br/>
                                    <div><strong>Motif :</strong>
                                        <t t-esc="claim.all_reasons"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- Détails des lignes de réclamation -->
                    <div class="card shadow-sm mb-5">
                        <div class="card-body">
                            <h4 class="mb-4">Détails des produits réclamés</h4>
                            <t t-if="claim.line_ids">
                                <div class="table-responsive">
                                    <table class="table table-striped table-hover">
                                        <thead class="table-light">
                                            <tr>
                                                <th class="text-start">Produit</th>
                                                <th class="text-start">Motif de réclamation</th>
                                                <th class="text-start">Quantité</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-foreach="claim.line_ids" t-as="line">
                                                <tr>
                                                    <td>
                                                        <t t-if="line.product_id">
                                                            <t t-esc="line.product_id.name"/>
                                                        </t>
                                                        <t t-else="">
                                                            <span class="text-muted">Produit non spécifié</span>
                                                        </t>
                                                    </td>
                                                    <td>
                                                        <t t-if="line.reason_display">
                                                            <t t-esc="line.reason_display"/>
                                                        </t>
                                                        <t t-else="">
                                                            <span class="text-muted">-</span>
                                                        </t>
                                                    </td>
                                                    <td>
                                                        <t t-esc="line.quantity"/>
                                                    </td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </div>
                            </t>
                            <t t-else="">
                                <div class="alert alert-info text-center">
                                    <i class="fa fa-info-circle"></i> Aucune ligne de réclamation trouvée.
                                </div>
                            </t>
                        </div>
                    </div>

                    <!-- Message de la réclamation -->
                    <div class="card shadow-sm mb-5">
                        <div class="card-body">
                            <h4 class="mb-4">Votre message</h4>
                            <div class="row">
                                <div class="col-12">
                                    <t t-if="claim.message">
                                        <p><t t-esc="claim.message"/></p>
                                    </t>
                                    <t t-else="">
                                        <span class="text-muted">Aucun message</span>
                                    </t>
                                </div>
                            </div>
                        </div>
                    </div>
                </t>
                <t t-else="">
                    <div class="alert alert-warning text-center">
                        <strong>Erreur :</strong> Réclamation introuvable ou non autorisée.
                    </div>
                </t>
            </div>
        </t>
    </template>

</odoo>
