<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- All orders -->
    <template id="orders_template" name="Commandes templates">
        <t t-call="website.layout">
            <div class="container py-5">
                <h2 class="o_cc o_cc1 text-center rounded-1 shadow-sm" style="background: linear-gradient(90deg, #38A935, #93C123); color: white; padding: 60px">
                    Toutes vos commandes
                </h2>

                <t t-if="orders">
                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead class="table-light">
                                <tr>
                                    <th>Commande</th>
                                    <th>Date</th>
                                    <th>Montant</th>
                                    <th>État</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="orders" t-as="order">
                                    <tr>
                                        <td><t t-esc="order.name"/></td>
                                        <td><t t-esc="order.date_order"/></td>
                                        <td>
                                            <t t-out="order.amount_total" t-options="{'widget': 'monetary', 'display_currency': order.currency_id}"/>
                                        </td>
                                        <td>
                                            <t t-if="order.state == 'draft'">
                                                <span class="badge text-bg-secondary">Devis</span>
                                            </t>
                                            <t t-elif="order.state == 'sent'">
                                                <span class="badge text-bg-info">Envoyé</span>
                                            </t>
                                            <t t-elif="order.state == 'sale'">
                                                <span class="badge text-bg-success">Commande client</span>
                                            </t>
                                            <t t-elif="order.state == 'cancel'">
                                                <span class="badge text-bg-danger">Annulé</span>
                                            </t>
                                            <t t-else="">
                                                <span class="badge text-bg-warning text-dark">Inconnu</span>
                                            </t>
                                        </td>

                                        <td class="text-end">
                                            <a t-att-href="'/client_orders_detail/%s' % order.id"
                                            class="btn btn-primary btn-md">
                                                Voir détail
                                            </a>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </t>

                <t t-else="">
                    <p class="text-muted">Aucune commande trouvée.</p>
                </t>

            </div>
        </t>
    </template>


