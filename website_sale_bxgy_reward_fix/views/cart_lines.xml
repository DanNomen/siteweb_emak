<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Hide the remove button for BXGY reward lines.
        Reward lines are managed automatically based on the main product.
    -->
    <template id="cart_lines_bxgy_reward" inherit_id="website_sale.cart_lines" priority="50">
        <xpath expr="//div[@name='o_wsale_cart_line_button_container']" position="attributes">
            <attribute name="t-attf-class">{{ 'd-none' if line.is_bxgy_reward else '' }}</attribute>
        </xpath>
    </template>
</odoo>
