<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Template to ensure line-id is always an integer for JS, even for ghost records -->
    <template id="cart_lines_deferred" inherit_id="website_sale.cart_lines">
        <xpath expr="//input[contains(@class, 'js_quantity')]" position="attributes">
            <attribute name="t-att-data-line-id">line.product_id.id</attribute>
        </xpath>
        <xpath expr="//input[@type='hidden'][contains(@class, 'js_quantity')]" position="attributes">
            <attribute name="t-att-data-line-id">line.product_id.id</attribute>
        </xpath>
    </template>

    <template id="navigation_buttons_deferred" inherit_id="website_sale.navigation_buttons">
        <xpath expr="//a[@t-att-href='step_specific_values[\'back_button_href\']']" position="attributes">
            <attribute name="t-att-href">
                '/produits' if step_specific_values['back_button_href'] == '/shop' else step_specific_values['back_button_href']
            </attribute>
        </xpath>
    </template>

    <template id="product_price_promo_badge" inherit_id="website_sale.product_price">
        <xpath expr="//h3[hasclass('css_editable_mode_hidden')]" position="inside">
            <span t-if="combination_info['has_discounted_price']" class="badge bg-danger ms-2 align-middle" style="font-size: 0.5em; vertical-align: middle;">PROMO</span>
        </xpath>
    </template>
</odoo>
