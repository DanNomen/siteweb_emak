<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="promotions_page" name="Promotions">
        <t t-call="website.layout">
            <div id="wrap" style="background-color: #F8F9FA; min-height: 80vh; font-family: 'Inter', sans-serif;">
                
                <style>
                    .promo-card {
                        background: #fff;
                        border-radius: 16px;
                        border: 1px solid #E5E7EB;
                        transition: box-shadow 0.2s ease, transform 0.2s ease;
                        overflow: hidden;
                        height: 100%;
                        display: flex;
                        flex-direction: column;
                    }
                    .promo-card:hover {
                        box-shadow: 0 8px 28px rgba(46,125,50,0.15);
                        transform: translateY(-3px);
                        border-color: #2E7D32;
                    }
                    .promo-img-container {
                        position: relative;
                        width: 100%;
                        padding-top: 100%; /* 1:1 Aspect Ratio */
                        background: #fff;
                    }
                    .promo-img {
                        position: absolute;
                        top: 0; left: 0; bottom: 0; right: 0;
                        width: 100%; height: 100%;
                        object-fit: contain;
                        padding: 1rem;
                    }
                    .promo-badge {
                        position: absolute;
                        top: 12px;
                        right: 12px;
                        background-color: #d32f2f;
                        color: white;
                        padding: 4px 12px;
                        border-radius: 20px;
                        font-weight: 700;
                        font-size: 0.8rem;
                        box-shadow: 0 2px 8px rgba(211, 47, 47, 0.4);
                        z-index: 2;
                    }
                    .promo-content {
                        padding: 1rem;
                        flex-grow: 1;
                        display: flex;
                        flex-direction: column;
                    }
                    .promo-title {
                        font-weight: 600;
                        color: #1f2937;
                        font-size: 0.95rem;
                        margin-bottom: 0.5rem;
                        display: -webkit-box;
                        -webkit-line-clamp: 2;
                        -webkit-box-orient: vertical;
                        overflow: hidden;
                    }
                    .btn-promo-details {
                        margin-top: auto;
                        background-color: #2E7D32;
                        color: white;
                        border-radius: 8px;
                        padding: 8px;
                        text-align: center;
                        font-weight: 600;
                        text-decoration: none;
                        transition: background-color 0.2s;
                    }
                    .btn-promo-details:hover {
                        background-color: #1b5e20;
                        color: white;
                    }
                </style>

                <!-- Bannière -->
                <div class="py-5 mb-4" style="background: linear-gradient(90deg, #38A935, #93C123);">
                    <div class="container text-center text-white">
                        <h2 class="fw-bold mb-1" style="font-family: 'Poppins', sans-serif;">
                            <i class="fa fa-tags me-2"></i>Nos Promotions
                        </h2>
                        <p class="mb-0 opacity-75">Découvrez toutes nos offres spéciales et articles en promotion.</p>
                    </div>
                </div>

                <div class="container pb-5">
                    <t t-if="products">
                        <div class="row g-4">
                            <t t-foreach="products" t-as="product">
                                <div class="col-6 col-md-4 col-lg-3">
                                    <div class="promo-card">
                                        <a t-att-href="'/shop/%s' % slug(product)" class="text-decoration-none">
                                            <div class="promo-img-container border-bottom">
                                                <div class="promo-badge">PROMOTION</div>
                                                <img t-att-src="'/web/image/product.template/%s/image_512' % product.id" 
                                                     class="promo-img" t-att-alt="product.name"/>
                                            </div>
                                        </a>
                                        <div class="promo-content">
                                            <a t-att-href="'/shop/%s' % slug(product)" class="text-decoration-none">
                                                <div class="promo-title"><t t-esc="product.name"/></div>
                                            </a>
                                            <!-- Prix -->
                                            <div class="mt-2 fw-bold" style="color: #2E7D32; font-size: 1.05rem;">
                                                <t t-if="product._get_contextual_price()">
                                                    <t t-esc="product._get_contextual_price()" t-options="{'widget': 'monetary', 'display_currency': website.currency_id}"/>
                                                </t>
                                            </div>
                                            <!-- Ajouter au panier (widget standard Odoo) -->
                                            <form action="/shop/cart/update" method="post" class="mt-3">
                                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                                <input type="hidden" name="product_id" t-att-value="product.product_variant_id.id"/>
                                                <!-- Quantité style Odoo shop -->
                                                <div class="css_quantity input-group d-inline-flex mb-2 w-100" style="max-width: 160px;">
                                                    <a href="#" class="btn btn-link js_add_cart_json border" aria-label="Remove one" title="Remove one"
                                                       style="color: #2E7D32; border-color: #dee2e6 !important;">
                                                        <i class="fa fa-minus"/>
                                                    </a>
                                                    <input type="number" min="1" name="add_qty" value="1"
                                                           class="form-control quantity text-center js_quantity"
                                                           style="border-left: 0; border-right: 0; appearance: auto; -moz-appearance: textfield; pointer-events: auto !important; user-select: text !important; -webkit-user-select: text !important;"/>
                                                    <a href="#" class="btn btn-link js_add_cart_json border" aria-label="Add one" title="Add one"
                                                       style="color: #2E7D32; border-color: #dee2e6 !important;">
                                                        <i class="fa fa-plus"/>
                                                    </a>
                                                </div>
                                                <button type="submit" class="btn-promo-details w-100" style="border:none; cursor:pointer;">
                                                    <i class="fa fa-shopping-cart me-1"></i> Ajouter au panier
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </t>
                        </div>
                    </t>
                    <t t-else="">
                        <div class="alert alert-warning text-center mt-5 py-5" style="border-radius: 12px; background-color: #fff3cd; border: 1px solid #ffe69c; color: #664d03;">
                            <i class="fa fa-exclamation-circle fa-3x mb-3 d-block opacity-75"></i>
                            <h4 class="fw-bold">Aucune promotion en cours</h4>
                            <p class="mb-0">Revenez plus tard pour découvrir nos offres spéciales.</p>
                        </div>
                    </t>
                </div>

            </div>
        </t>
    </template>
</odoo>
